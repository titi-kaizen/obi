# ── Database ──────────────────────────────────────────────────────────────────
# Supabase direct connection (bypass RLS)
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL_SYNC=postgresql+psycopg2://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Supabase (optional, for JWT auth) ─────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── AI Providers ─────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PREFERRED_AI_PROVIDER=groq  # groq | anthropic

# ── Scraping ─────────────────────────────────────────────────────────────────
SCRAPE_CONCURRENCY=8
SCRAPE_TIMEOUT_SECONDS=25
PLAYWRIGHT_TIMEOUT_MS=20000
ENABLE_PLAYWRIGHT=true
ENABLE_DEBUG_SCREENSHOTS=false
SCREENSHOTS_DIR=/tmp/obi_screenshots

# ── Pipeline ─────────────────────────────────────────────────────────────────
MIN_OG_RELEVANCE_FOR_LLM=0.15
MIN_OG_RELEVANCE_TO_STORE=0.05
AI_CONCURRENCY=4
AI_RATE_LIMIT_DELAY_MS=500

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","https://web-theta-seven-58.vercel.app"]
