# ─── OGASCI — Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# ─── Email Alerts (SMTP) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=OGASCI Alerts <alerts@ogasci.com>

# ─── Slack Alerts ─────────────────────────────────────────────────────────────
SLACK_ALERTS_WEBHOOK=https://hooks.slack.com/services/...
SLACK_DEPLOY_WEBHOOK=https://hooks.slack.com/services/...  # optional, for deploy notifications

# ─── Scraping ─────────────────────────────────────────────────────────────────
# Set to 'false' to disable Playwright dynamic scraping (useful in environments without Chrome)
ENABLE_DYNAMIC_SCRAPING=true
